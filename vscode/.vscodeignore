# vsce package excludes everything matching these patterns from the .vsix.
# We ship: dist/ (bundled JS, copied webview.html, copied proto/gil/v1/*.proto),
# README, package.json, LICENSE.

# Source — bundled into dist/
src/**
**/*.ts
**/*.map

# Build tooling
esbuild.mjs
tsconfig.json
node_modules/**
.vscode-test/**

# Operator-only docs (not for end users installing the extension)
PACKAGING.md

# Dev / test artifacts
**/*.test.js
**/*.spec.js
.gitignore
.npmrc
.vscodeignore

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
