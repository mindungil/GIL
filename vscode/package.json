{
	"name": "gil",
	"displayName": "gil — Autonomous Coding Harness",
	"description": "VS Code panel for the gil autonomous coding harness. Lists sessions managed by the gild daemon, tails their event streams, and triggers runs.",
	"version": "0.1.0",
	"publisher": "gil",
	"license": "Apache-2.0",
	"engines": {
		"vscode": "^1.84.0"
	},
	"categories": [
		"AI",
		"Other"
	],
	"keywords": [
		"gil",
		"agent",
		"autonomous",
		"coding"
	],
	"main": "./dist/extension.js",
	"activationEvents": [
		"onCommand:gil.startSession",
		"onCommand:gil.runSession",
		"onCommand:gil.tailEvents",
		"onCommand:gil.openPanel",
		"onView:gilSessions"
	],
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "gil-sidebar",
					"title": "gil",
					"icon": "$(rocket)"
				}
			]
		},
		"views": {
			"gil-sidebar": [
				{
					"type": "webview",
					"id": "gilSessions",
					"name": "Sessions"
				}
			]
		},
		"commands": [
			{
				"command": "gil.startSession",
				"title": "gil: Start Session",
				"category": "gil"
			},
			{
				"command": "gil.runSession",
				"title": "gil: Run Session",
				"category": "gil"
			},
			{
				"command": "gil.tailEvents",
				"title": "gil: Tail Session Events",
				"category": "gil"
			},
			{
				"command": "gil.openPanel",
				"title": "gil: Open Panel",
				"category": "gil"
			}
		],
		"configuration": {
			"title": "gil",
			"properties": {
				"gil.socketPath": {
					"type": "string",
					"default": "",
					"description": "Override path to the gild UDS socket. If empty, uses $GILD_SOCKET or ~/.gil/gild.sock."
				}
			}
		}
	},
	"scripts": {
		"build": "node esbuild.mjs",
		"watch": "node esbuild.mjs --watch",
		"check-types": "tsc --noEmit -p .",
		"package": "npm run build -- --production && vsce package --no-yarn"
	},
	"dependencies": {
		"@grpc/grpc-js": "^1.10.0",
		"@grpc/proto-loader": "^0.7.10"
	},
	"devDependencies": {
		"@types/node": "20.x",
		"@types/vscode": "^1.84.0",
		"@vscode/vsce": "^3.0.0",
		"esbuild": "^0.25.0",
		"typescript": "^5.6.0"
	}
}
